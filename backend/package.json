{
  "name": "pollstraw-backend",
  "version": "1.0.0",
  "description": "PollStraw - Real-time Polling Platform API",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "npm run db:generate && tsc && npm run copy:public",
    "copy:public": "node scripts/copy-public.js",
    "start": "node dist/app.js",
    "postinstall": "npm run db:generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:test": "node -e \"require('dotenv').config({path:'.env.test'}); require('child_process').execSync('npx prisma db push', {stdio:'inherit', env:process.env})\"",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "admin:promote": "tsx scripts/promote-to-admin.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest --config jest.config.cjs",
    "load-test": "node scripts/run-load-test.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.4",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.9.0",
    "socket.io-client": "^4.7.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
